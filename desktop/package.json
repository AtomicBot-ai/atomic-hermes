{
  "name": "hermes-desktop",
  "version": "0.1.0",
  "description": "Atomic Hermes — self-contained macOS desktop app",
  "main": "dist/main/main.js",
  "private": true,
  "scripts": {
    "build:ts": "tsc",
    "build:dashboard": "npm --prefix ../web install && npm --prefix ../web run build",
    "build:renderer": "vite build --config renderer/vite.config.ts",
    "build:all": "npm run build:dashboard && npm run build:ts && npm run build:renderer",
    "start": "npm run build:all && electron .",
    "dev": "bash scripts/bundle-dev.sh && npm run build:dashboard && npm run build:renderer && tsc && (tsc -w --preserveWatchOutput & electron .)",
    "bundle": "bash scripts/bundle-all.sh",
    "bundle:dev": "bash scripts/bundle-dev.sh",
    "dist": "npm run build:all && electron-builder"
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "react-hot-toast": "^2.6.0"
  },
  "devDependencies": {
    "@reduxjs/toolkit": "^2.9.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.3",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.13.0",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "typescript": "^5.6.0",
    "vite": "^7.3.1"
  },
  "build": {
    "appId": "com.nousresearch.hermes-agent",
    "productName": "Atomic Hermes",
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "assets/icon.icns"
    },
    "extraResources": [
      {
        "from": "build/python",
        "to": "python"
      },
      {
        "from": "build/hermes-venv",
        "to": "hermes-venv"
      },
      {
        "from": "build/hermes-agent",
        "to": "hermes-agent"
      },
      {
        "from": "build/bin",
        "to": "bin"
      },
      {
        "from": "build/node_modules",
        "to": "node_modules"
      },
      {
        "from": "build/skills",
        "to": "skills"
      },
      {
        "from": "src/python-server",
        "to": "python-server"
      }
    ],
    "files": [
      "dist/**/*",
      "renderer/dist/**/*"
    ]
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
